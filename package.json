{
  "name": "sdtm-backend",
  "version": "1.0.0",
  "description": "Backend SDTM - Arquitetura Cofre de Vidro",
  "type": "module",
  "scripts": {
    "dev": "npx serve . -p 3000",
    "dev:api": "npx vercel@latest dev",
    "deploy": "vercel --prod",
    "db:migrate": "node sql/migrate.js",
    "db:migrate:inscricao": "node sql/migrate-inscricao.js",
    "db:migrate:cadastro-data": "node sql/migrate-cadastro-data.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.0",
    "@upstash/ratelimit": "^1.0.0",
    "@upstash/redis": "^1.28.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.3.1",
    "jsonwebtoken": "^9.0.2",
    "pdf-lib": "^1.17.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "serve": "^14.2.6",
    "vercel": "^33.7.1",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
